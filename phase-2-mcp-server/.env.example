# --- Core ---
VAULT_PATH=/data/vault
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=vault_chunks
VOYAGE_API_KEY=
QUERY_MODEL=voyage-3.5
RERANK_MODEL=rerank-2.5
EMBED_DIM=1024

# --- Server ---
BEARER_TOKEN=
HOST=0.0.0.0
PORT=8000
PUBLIC_DOMAIN=mcp.example.com
LOG_LEVEL=INFO

# --- Google Tasks (Phase 4) ---
GOOGLE_CLIENT_SECRETS_PATH=/data/secrets/google_client_secret.json
GTASKS_TOKEN_PATH=/data/secrets/gtasks_token.enc
GTASKS_TOKEN_KEY=

# --- MeetGeek (Phase 5) ---
MEETGEEK_API_TOKEN=

# --- Fireflies + Google Calendar (Phase 5b) ---
# The calendar lives in a different Google workspace than Tasks, so it
# uses its own OAuth client secrets file.
FIREFLIES_API_KEY=
FIREFLIES_WEBHOOK_SECRET=
GCAL_CLIENT_SECRETS_PATH=/data/secrets/gcal_client_secret.json
GCAL_TOKEN_PATH=/data/secrets/gcal_token.enc
GCAL_TOKEN_KEY=
