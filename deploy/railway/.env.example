# =============================================================================
# Variables for the combined "second-brain" Railway service.
# All paths are inside the container; the volume is mounted at /data.
# =============================================================================

# --- Filesystem layout (don't change unless you know what you're doing) ----
VAULT_PATH=/data/vault
SECRETS_DIR=/data/secrets
LIVESYNC_STATE_PATH=/data/state/livesync.json

# --- Cross-service references (Railway templates) --------------------------
# Replace ${{Qdrant.RAILWAY_PRIVATE_DOMAIN}} and ${{Couchdb.RAILWAY_PRIVATE_DOMAIN}}
# with the actual service names you used in Railway.
QDRANT_URL=http://${{Qdrant.RAILWAY_PRIVATE_DOMAIN}}:6333
QDRANT_COLLECTION=vault_chunks

COUCHDB_URL=http://${{Couchdb.RAILWAY_PRIVATE_DOMAIN}}:5984
COUCHDB_DB=obsidian
COUCHDB_USER=${{Couchdb.COUCHDB_USER}}
COUCHDB_PASSWORD=${{Couchdb.COUCHDB_PASSWORD}}

# --- Voyage AI -------------------------------------------------------------
VOYAGE_API_KEY=

# --- MCP server ------------------------------------------------------------
# Auth options (pick ONE):
#
#   (a) Google OAuth -- recommended for multi-user / Teams plans. Each
#       Claude.ai user logs in with their Google account and only those
#       in ALLOWED_EMAILS are admitted. Create an OAuth client of type
#       "Web application" in Google Cloud Console and add the redirect
#       URI <OAUTH_BASE_URL>/auth/callback.
#
#   (b) Bearer token -- single shared token in the connector config.
#       Simpler but anyone with the token can access the server.
#
# If both are set, OAuth takes precedence and BEARER_TOKEN is ignored.

# (a) Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
OAUTH_BASE_URL=https://${{RAILWAY_PUBLIC_DOMAIN}}
# Comma-separated list of allowed Google account emails.
ALLOWED_EMAILS=

# (b) Bearer token. 32+ random chars. Only consulted if OAuth is unset.
BEARER_TOKEN=

HOST=0.0.0.0
# Do NOT set PORT here. Railway injects it automatically per service and
# overriding it will break the public proxy.
PUBLIC_DOMAIN=${{RAILWAY_PUBLIC_DOMAIN}}
LOG_LEVEL=INFO

# --- Indexer ---------------------------------------------------------------
INDEX_INCLUDE_DIRS=10_Projects,20_Areas,30_Resources,50_Daily,60_MOCs,70_People
INDEX_EXCLUDE_DIRS=00_Inbox,40_Archive,99_Meta,.obsidian
CHUNK_MAX_TOKENS=800
CHUNK_WINDOW_TOKENS=500
CHUNK_OVERLAP_TOKENS=80

# --- Google Tasks (optional) -----------------------------------------------
# Run gtasks-auth locally, then base64-encode the resulting files and paste:
#   base64 -i ~/.gtasks/gtasks_token.enc | pbcopy   # macOS
#   base64 -w0 gtasks_token.enc                     # Linux
GOOGLE_CLIENT_SECRETS_PATH=/data/secrets/google_client_secret.json
GTASKS_TOKEN_PATH=/data/secrets/gtasks_token.enc
GTASKS_TOKEN_KEY=
GOOGLE_CLIENT_SECRETS_B64=
GTASKS_TOKEN_B64=

# --- MeetGeek (optional) ---------------------------------------------------
MEETGEEK_WEBHOOK_SECRET=

# =============================================================================
# Variables for the COUCHDB Railway service (configure on that service):
# =============================================================================
# COUCHDB_USER=admin
# COUCHDB_PASSWORD=<generate>
# (No volumes config needed — see railway.couchdb.json.)
